                "varhelp": "",
                "vartype": "string",
                "varinput": 
                {
                    "control": "text"
                }
            },
            {
                "varname": "vendesk_ext_notif",
                "vardefault": "",
                "varvalue": "",
                "varcaption": "Canal de notificaciones externas:",
                "vartype": "string",
                "varinput": 
                {
                    "control": "select",
                    "source":
                    {
                        "type":"query",
                        "query":"SELECT 0 sys_pk,'(Ninguno)' name union SELECT c.sys_pk, c.name FROM snd_channel c  INNER JOIN snd_provider p ON c.prov=p.sys_pk INNER JOIN snd_provider_tpy pt ON p.tpy = pt.id WHERE pt.id=0",
                        "keyfield":"sys_pk",
                        "showfield":"name"
                    }
                }
            },
            {
                "varname": "vendesk_sise_opntkt",
                "vardefault": "0",
                "varvalue": "0",
                "varcaption": "Apertura máxima por SISE.",
                "varhelp": "Apertura máxima de tickes(casos) pro SISE.",
                "vartype": "integer",
                "varinput": 
                {
                    "control": "select",
                    "source":
                    {
                        "type":"list",
                        "values":
                        [
                            {"val":"0", "text":"Sin límite"},
                            {"val":"1", "text":"Uno a la vez"},
                            {"val":"2", "text":"Uno por tipo"}
                        ],
                        "showfield":"text",
                        "keyfield":"val"
                    }
                }
            }
        ]
    }
