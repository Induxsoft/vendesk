#include "dkli.dkh"
#!
module ""
{
    #include "functions.dkh"
    #include "serialize.dkh"
    #include "dbr.dkh"
    #include "webcl.dkh"
    #include "vendesk/config.dkl"
    #include "vendesk/_lib/lib.dk"
    #include "vendesk/_services/lib.dk"
    #include "model.dk"
    
    res= rest.EntryPoint("open-ticket")

    exception
    {
        res="Ha ocurrido un error al intentar registrar la información del ticket. Información técnica: "+last_error()
    }

    do rest.ResponseText(res)
}